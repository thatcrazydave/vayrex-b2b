# Production Environment Configuration for Netlify
# Set these variables in Netlify Dashboard: Site settings > Build & deploy > Environment variables

# ===== Frontend API Connection (Your Local Backend via ngrok) =====
VITE_API_URL=https://sometimes-unforward-candra.ngrok-free.dev/api

# ===== Legacy Config (Not needed for Netlify frontend) =====
API_URL=https://api.vayrex.com/api
FRONTEND_URL=https://vayrex.com

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=your-prod-access-key
AWS_SECRET_ACCESS_KEY=your-prod-secret-key
AWS_REGION=us-east-1
S3_BUCKET=vayrex-production

# ===== CloudFront =====
CLOUDFRONT_ID=E1234567890XYZ

# ===== Backend Deployment =====
DEPLOY_SERVER=prod-server-1.vayrex.com
DEPLOY_USER=vayrex
DEPLOY_PATH=/opt/vayrex
DEPLOY_KEY=~/.ssh/vayrex_prod_deploy

# ===== Database =====
MONGODB_URI=mongodb+srv://user:password@prod-cluster.mongodb.net/vayrex
REDIS_URL=redis://prod-redis:6379

# ===== API Configuration =====
JWT_SECRET=your-production-jwt-secret-key
OPENAI_API_KEY=sk-your-prod-openai-api-key

# ===== Notifications =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/PROD/WEBHOOK
DEPLOYMENT_NOTIFICATIONS_ENABLED=true

# ===== Monitoring =====
DATADOG_API_KEY=your-datadog-key
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# Staging Environment Configuration
# Used by: deploy-frontend.sh, deploy-backend.sh, health-check.sh

# ===== Frontend =====
API_URL=https://staging-api.vayrex.com/api
FRONTEND_URL=https://staging.vayrex.com

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=your-staging-access-key
AWS_SECRET_ACCESS_KEY=your-staging-secret-key
AWS_REGION=us-east-1
S3_BUCKET=vayrex-staging

# ===== CloudFront (optional) =====
CLOUDFRONT_ID=E1234567890ABC

# ===== Backend Deployment =====
DEPLOY_SERVER=staging-server.vayrex.com
DEPLOY_USER=vayrex
DEPLOY_PATH=/opt/vayrex
DEPLOY_KEY=~/.ssh/vayrex_staging_deploy

# ===== Database =====
MONGODB_URI=mongodb+srv://user:password@staging-cluster.mongodb.net/vayrex
REDIS_URL=redis://staging-redis:6379

# ===== API Configuration =====
JWT_SECRET=your-staging-jwt-secret-key
OPENAI_API_KEY=sk-your-openai-api-key

# ===== Notifications =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DEPLOYMENT_NOTIFICATIONS_ENABLED=true

